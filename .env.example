# Site
MOODLE_SITE_NAME=Moodle
MOODLE_SITE_URL=https://moodle.example.com

# Admin account (used during initial DB install)
# Generate a strong password: openssl rand -base64 24
MOODLE_INSTALL_ADMIN_PASS='your-admin-password'
MOODLE_INSTALL_ADMIN_EMAIL=moodle@your-email-domain.tld

# Database
MOODLE_DB_HOST=mariadb
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
# Generate a strong password: openssl rand -base64 24
MOODLE_DB_PASS='your-db-password'
MOODLE_DB_PORT=3306
